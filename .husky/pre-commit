#!/bin/sh

echo "🔍 Pre-commit: Running lint-staged (Prettier + ESLint on changed files)..."
npx lint-staged

# Get changed TypeScript/JavaScript files to check which modules changed
changedFiles=$(git diff --cached --name-only --diff-filter=d | grep -E '\.(ts|js)$' || true)

if [ -z "$changedFiles" ]; then
  echo "\n✅ Pre-commit: Ingen TypeScript/JavaScript filer endret - hopper over type-sjekk og lisenssjekk"
  exit 0
fi

# Extract unique modules from changed files
modules=$(echo "$changedFiles" | grep -E '^(get-release-notes|validate-pull-request-title|publish-release-notes|github-app-token|write-to-influxdb)/' | cut -d'/' -f1 | sort -u)

if [ -z "$modules" ]; then
  echo "\n✅ Pre-commit: Ingen TypeScript/Node.js moduler endret - hopper over type-sjekk og lisenssjekk"
  exit 0
fi

echo "\n📦 Pre-commit: Endrede moduler - $(echo $modules | tr '\n' ' ')"
echo "   Kjører type-sjekk (TypeScript) og lisenssjekk på disse modulene...\n"

# Run type check and license check on changed modules
failed=false
for module in $modules; do
  echo "🔍 Pre-commit: Type-sjekker $module (tsc --noEmit)..."
  if (cd $module && npx tsc --noEmit); then
    echo "✅ Type check passed"
  else
    echo "❌ Type check failed"
    failed=true
  fi
  
  echo "\n📋 Pre-commit: Sjekker lisenser i $module (npm run lisenssjekk)..."
  if (cd $module && npm run lisenssjekk >/dev/null 2>&1); then
    echo "✅ License check passed"
  else
    echo "❌ License check failed"
    failed=true
  fi
  echo ""
done

if [ "$failed" = true ]; then
  echo "❌ Pre-commit: Noen sjekker feilet. Rett feilene før du committer."
  exit 1
fi

echo "✅ Pre-commit: Alle sjekker fullført!"
exit 0
